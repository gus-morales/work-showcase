# OS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# Data / models (avoid committing large artifacts)
*.csv
*.parquet
*.pkl
*.h5
data/raw/
data/interim/

# Project 08 (Observatory): the DuckDB database is regenerated by
# src/generate_data.py. snapshot/ and dashboard/ are committed, they're
# the showcased deliverables, not just build output.
projects/08-observatory/data/*.duckdb*
!projects/08-observatory/snapshot/flags.csv

# Project 09 (ML Pipeline Contracts): training_data.parquet, features.parquet,
# and the model .pkl files are regenerated by src/orchestrator.py and stay
# ignored by the blanket rules above; feature_importance.csv is small,
# committed light output, like every other artifact under runs/.
!projects/09-ml-pipeline-contracts/runs/**/artifacts/model/feature_importance.csv

# Env / secrets
.env

# Editors
.vscode/
.idea/
